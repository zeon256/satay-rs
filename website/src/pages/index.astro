---
import Layout from "@/layouts/main.astro"
import { CopyButton } from "@/components/landing/CopyButton"
import { satayUsers, USERS_FILE_PATH, USERS_SUBMISSION_URL } from "@/data/users"
import { fetchProjectStats, formatDownloads, formatStars } from "@/lib/stats"
import {
  ArrowSquareOutIcon,
  BookOpenIcon,
  CodeIcon,
  DownloadSimpleIcon,
  GithubLogoIcon,
  GitBranchIcon,
  PackageIcon,
  PlugsIcon,
  PlusIcon,
  ShieldCheckIcon,
  StarIcon,
  UsersThreeIcon,
  WarningIcon,
  GlobeHemisphereEastIcon,
  XCircleIcon,
  CheckCircleIcon,
} from "@phosphor-icons/react"

const GITHUB_URL = "https://github.com/zeon256/satay-rs"
const CRATES_URL = "https://crates.io/crates/satay-cli"
const DOCS_URL = "https://docs.rs/satay-codegen"
const INSTALL_CMD = "cargo install satay-cli"
const GENERATE_CMD = "satay generate --input openapi.yaml --output src/generated --rustfmt"

const { crateDownloads, githubStars } = await fetchProjectStats()

const sectionLinks = [
  { href: "#origin", label: "Origin" },
  { href: "#why-sans-io", label: "sans-IO" },
  { href: "#features", label: "Features" },
  { href: "#users", label: "Users" },
  { href: "#how-it-works", label: "How it works" },
]

const sansIoContrast = [
  {
    title: "Without sans-IO",
    points: [
      "Async, blocking, and WASM each need their own client code path",
      "Security and feature changes in reqwest, hyper, or ureq become your release work",
      "Swapping transports means refactoring the client internals",
      "Tests often need real HTTP or heavy mocks around the whole stack",
    ],
    icon: XCircleIcon,
    variant: "without" as const,
  },
  {
    title: "With Satay",
    points: [
      "One generated surface for building requests and decoding responses",
      "Transport adapters are thin and optional. Your app keeps the HTTP client",
      "Backend updates stay at the edge. Regenerate when the spec changes, not when reqwest bumps",
      "Unit tests can build requests and decode responses without the network",
    ],
    icon: CheckCircleIcon,
    variant: "with" as const,
  },
]

const features = [
  {
    title: "sans-IO first",
    body: "Actions build plain <code class=\"code-inline\">http::Request</code> values. Send them with reqwest, ureq, hyper, tests, WASM, or whatever you already run.",
    icon: PlugsIcon,
  },
  {
    title: "Validation newtypes",
    body: "String, number, integer, and array constraints from the spec become nutype newtypes. Bounds narrow to <code class=\"code-inline\">u8</code> when the maximum allows it.",
    icon: ShieldCheckIcon,
  },
  {
    title: "OpenAPI 3.1",
    body: "Reads the spec into a normalized IR, then emits structs, enums, builders, and decoders as ordinary Rust you can edit.",
    icon: CodeIcon,
  },
  {
    title: "Optional adapters",
    body: "Stay IO-free, or pull in <code class=\"code-inline\">satay-reqwest</code> and <code class=\"code-inline\">satay-ureq</code> when you want a short <code class=\"code-inline\">send_with</code> call site.",
    icon: GitBranchIcon,
  },
]

---

<Layout>
  <div id="top" class="relative flex min-h-svh flex-col overflow-x-clip">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="bg-terracotta/12 absolute -top-28 right-[8%] size-72 rounded-full blur-3xl"></div>
      <div class="bg-ember/10 absolute bottom-[18%] -left-20 size-64 rounded-full blur-3xl"></div>
      <div class="skewer-diagonal absolute inset-0"></div>
    </div>

    <div class="site-chrome animate-rise fixed inset-x-0 top-0 z-50">
      <aside class="site-banner" role="note">
        <div class="site-banner-inner">
          <WarningIcon className="text-ember size-3.5 shrink-0" />
          <p class="text-cream-muted min-w-0 text-xs leading-snug">
            <span class="text-cream font-medium">Work in progress.</span>
            Focused on lta-rs-style clients for now.
          </p>
        </div>
      </aside>

      <header class="site-header">
        <div class="site-header-inner">
          <a href="#top" class="group flex shrink-0 items-center gap-3">
            <img
              src="/logo.webp"
              alt=""
              width="36"
              height="36"
              class="size-9 rounded-lg shadow-md shadow-black/40 transition-transform group-hover:scale-[1.03]"
            />
            <span class="font-heading text-lg font-semibold tracking-tight">Satay</span>
          </a>

          <div class="header-nav-cluster">
            <nav class="header-section-nav" aria-label="Page sections">
              {
                sectionLinks.map((link) => (
                  <a href={link.href} class="header-section-link">
                    {link.label}
                  </a>
                ))
              }
            </nav>

            <div class="header-nav-divider" aria-hidden="true"></div>

            <nav class="header-external-nav" aria-label="External links">
              <a href={DOCS_URL} target="_blank" rel="noreferrer" class="btn-ghost">
                <BookOpenIcon className="size-4" />
                <span class="hidden sm:inline">Docs</span>
              </a>
              <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="btn-ghost">
                <GithubLogoIcon className="size-4" />
                <span class="hidden sm:inline">GitHub</span>
              </a>
            </nav>
          </div>
        </div>
      </header>
    </div>

    <main class="main-with-fixed-chrome relative z-10 mx-auto flex w-full max-w-6xl flex-1 flex-col px-6 pb-20 md:px-10">
      <div class="grid items-center gap-14 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)] lg:gap-16">
        <section class="flex flex-col gap-8">
          <p class="meta-row animate-rise delay-150" aria-label="Project metadata">
            <span class="text-terracotta">sans-IO</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>OpenAPI 3.1</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>Rust 2024</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>MSRV 1.88</span>
          </p>

          {(crateDownloads !== null || githubStars !== null) && (
            <div class="stat-row animate-rise delay-175">
              {crateDownloads !== null && (
                <a href={CRATES_URL} target="_blank" rel="noreferrer" class="stat-pill">
                  <DownloadSimpleIcon className="size-3.5" />
                  {formatDownloads(crateDownloads)}
                </a>
              )}
              {githubStars !== null && (
                <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="stat-pill">
                  <StarIcon className="size-3.5" weight="fill" />
                  {formatStars(githubStars)}
                </a>
              )}
            </div>
          )}

          <div class="animate-rise delay-200 space-y-5">
            <h1
              class="font-heading text-[2.75rem] leading-[1.02] font-semibold tracking-tight md:text-6xl lg:text-[4.25rem]"
            >
              OpenAPI clients
              <span class="text-terracotta block">without picking a transport</span>
            </h1>
            <p class="text-cream-muted max-w-xl text-base leading-relaxed md:text-lg">
              Satay turns a spec into request builders, response decoders, and validation newtypes. You send the
              <code class="code-inline">http::Request</code> with reqwest, ureq, hyper, or whatever you already run.
            </p>
          </div>

          <div class="animate-rise delay-300 flex flex-wrap items-center gap-3">
            <a href={CRATES_URL} target="_blank" rel="noreferrer" class="btn btn-primary">
              <DownloadSimpleIcon className="size-5" />
              Install CLI
            </a>
            <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="btn btn-outline">
              <GithubLogoIcon className="size-5" />
              View source
            </a>
          </div>

          <div class="animate-rise delay-400 w-full max-w-lg space-y-2">
            <p class="text-cream-muted text-[0.7rem] font-medium tracking-[0.22em] uppercase">Quick start</p>
            <div class="terminal-block">
              <div class="terminal-header">
                <span class="terminal-dot bg-terracotta/80"></span>
                <span class="terminal-dot bg-cream-muted/40"></span>
                <span class="terminal-dot bg-cream-muted/25"></span>
                <span class="terminal-label">shell</span>
              </div>
              <div class="flex items-center justify-between gap-3 px-4 py-3.5">
                <code class="terminal-code">{INSTALL_CMD}</code>
                <CopyButton client:load value={INSTALL_CMD} label="Copy install command" />
              </div>
            </div>
          </div>
        </section>

        <section class="animate-rise delay-500 relative flex items-center justify-center">
          <div
            class="bg-terracotta-deep/25 absolute inset-[12%] rounded-[2.5rem] blur-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/logo.webp"
            alt="Satay logo: cubes on a skewer, standing in for OpenAPI, codegen, and transport adapters"
            width="480"
            height="480"
            fetchpriority="high"
            class="animate-logo-float relative z-10 w-full max-w-[22rem] drop-shadow-2xl drop-shadow-black/60 lg:max-w-[26rem]"
          />
        </section>
      </div>

      <section class="section-anchor animate-rise delay-550 mt-24" id="origin">
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start lg:gap-16">
          <div class="space-y-6">
            <div class="space-y-3">
              <p class="text-terracotta text-xs font-medium tracking-[0.24em] uppercase">Origin</p>
              <h2 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">
                Named for the skewer, not the sauce
              </h2>
            </div>

            <article class="origin-entry" aria-label="Dictionary entry for sate">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <p class="origin-headword">sate</p>
                <p class="origin-pronunciation">/ˈsɑː.teɪ/</p>
                <p class="origin-pronunciation italic">n.</p>
                <p class="origin-pronunciation">(Malay, Indonesian)</p>
              </div>
              <p class="origin-gloss">
                a skewer; meat (or other food) cut into pieces, threaded onto a skewer, and grilled.
              </p>
            </article>

            <div class="text-cream-muted space-y-4 text-base leading-relaxed">
              <p>
                English <strong class="text-cream font-medium">satay</strong> comes from the Malay and Indonesian word
                <strong class="text-cream font-medium">sate</strong>, which refers to both the skewer and the dish.
                Street vendors thread marinated pieces onto bamboo sticks, grill them over charcoal, and serve them with
                peanut sauce. The name caught on abroad as the dish spread across Southeast Asia.
              </p>
            </div>
          </div>

          <div class="space-y-6 lg:pt-12">
            <div class="bg-terracotta/15 text-terracotta inline-flex size-10 items-center justify-center rounded-xl">
              <GlobeHemisphereEastIcon className="size-5" />
            </div>
            <p class="text-cream-muted text-base leading-relaxed">
              Satay-rs leans into that image. OpenAPI describes the pieces: schemas, operations, constraints. Codegen
              threads them into typed request builders and response decoders. Your application picks the transport and
              sends them through. The skewer is the sans-IO boundary. The pieces stay the same no matter which grill you
              use.
            </p>

            <ol class="origin-metaphor-list" aria-label="How the skewer metaphor maps to Satay">
              <li class="origin-metaphor-item">
                <span class="origin-metaphor-marker" aria-hidden="true"></span>
                <div>
                  <p class="text-cream font-medium">OpenAPI spec</p>
                  <p class="text-cream-muted mt-1 text-sm leading-relaxed">The marinated pieces: schemas, operations, constraints.</p>
                </div>
              </li>
              <li class="origin-metaphor-item">
                <span class="origin-metaphor-marker" aria-hidden="true"></span>
                <div>
                  <p class="text-cream font-medium">Codegen</p>
                  <p class="text-cream-muted mt-1 text-sm leading-relaxed">Threads them into builders and decoders you can read.</p>
                </div>
              </li>
              <li class="origin-metaphor-item">
                <span class="origin-metaphor-marker" aria-hidden="true"></span>
                <div>
                  <p class="text-cream font-medium">Your transport</p>
                  <p class="text-cream-muted mt-1 text-sm leading-relaxed">
                    reqwest, ureq, hyper, tests, WASM, WebSocket, or your own client.
                  </p>
                </div>
              </li>
              <li class="origin-metaphor-item">
                <span class="origin-metaphor-marker" aria-hidden="true"></span>
                <div>
                  <p class="text-cream font-medium">sans-IO boundary</p>
                  <p class="text-cream-muted mt-1 text-sm leading-relaxed">The skewer itself. Same pieces, different grill.</p>
                </div>
              </li>
            </ol>
          </div>
        </div>
      </section>

      <section class="section-anchor animate-rise delay-575 mt-24" id="why-sans-io">
        <div class="mb-10 max-w-2xl space-y-3">
          <p class="text-terracotta text-xs font-medium tracking-[0.24em] uppercase">Why sans-IO</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">
            Maintain the API, not the HTTP client
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Most OpenAPI clients bundle a transport. Your SDK ends up tracking reqwest releases, TLS changes, and
            separate async, blocking, and WASM code paths. Satay generates the API layer only. You send the requests
            yourself.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            sansIoContrast.map((side, index) => {
              const Icon = side.icon
              return (
                <article
                  class:list={["contrast-card animate-rise", side.variant === "with" && "contrast-card--with"]}
                  style={`animation-delay: ${600 + index * 75}ms`}
                >
                  <div class="card-body">
                    <div class="mb-5 flex items-center gap-3">
                      <div
                        class:list={[
                          "inline-flex size-10 items-center justify-center rounded-xl",
                          side.variant === "with" ? "bg-terracotta/15 text-terracotta" : "bg-cream/5 text-cream-muted",
                        ]}
                      >
                        <Icon className="size-5" weight={side.variant === "with" ? "fill" : "regular"} />
                      </div>
                      <h3 class="font-heading text-xl font-semibold">{side.title}</h3>
                    </div>
                    <ul class="contrast-list">
                      {side.points.map((point) => (
                        <li class="contrast-list-item">
                          <span class="contrast-list-marker" aria-hidden="true"></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </article>
              )
            })
          }
        </div>

        <p class="text-cream-muted mt-8 max-w-2xl text-base leading-relaxed">
          You maintain only the OpenAPI spec. Satay turns it into typed Rust. When the API changes, update the spec and
          regenerate. Your HTTP client stays separate.
        </p>
      </section>

      <section class="section-anchor animate-rise delay-600 mt-24" id="features">
        <div class="mb-10 max-w-2xl space-y-3">
          <p class="text-terracotta text-xs font-medium tracking-[0.24em] uppercase">Features</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">
            Rust you can read, not template soup
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Builders, decoders, and validation newtypes from your OpenAPI spec.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            features.map((feature, index) => {
              const Icon = feature.icon
              return (
                <article class="surface-card surface-card--feature animate-rise" style={`animation-delay: ${650 + index * 75}ms`}>
                  <div class="card-art" aria-hidden="true">
                    <div class="card-art-well">
                      <Icon className="card-art-icon" weight="thin" />
                    </div>
                  </div>
                  <div class="card-body">
                    <h3 class="font-heading mb-2 text-xl font-semibold">{feature.title}</h3>
                    <p class="text-cream-muted text-sm leading-relaxed" set:html={feature.body} />
                  </div>
                </article>
              )
            })
          }
        </div>
      </section>

      <section class="section-anchor animate-rise delay-650 mt-24" id="users">
        <div class="mb-10 max-w-2xl space-y-3">
          <p class="text-terracotta text-xs font-medium tracking-[0.24em] uppercase">Built with Satay</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">
            In the wild
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Open-source API clients built with Satay. Got one? Send a PR.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            satayUsers.map((user, index) => (
              <article
                class="surface-card animate-rise"
                style={`animation-delay: ${700 + index * 75}ms`}
              >
                <div class="card-art" aria-hidden="true">
                  <div class:list={["card-art-well", !user.logo && "card-art-well--mark"]}>
                    {
                      user.logo ? (
                        <img
                          src={user.logo}
                          alt=""
                          class="card-art-image"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <span class="card-art-mark">{user.name.slice(0, 2)}</span>
                      )
                    }
                  </div>
                </div>
                <div class="card-body">
                  <h3 class="font-heading text-xl font-semibold">
                    <a
                      href={user.href}
                      target="_blank"
                      rel="noreferrer"
                      class="user-card-title inline-flex items-center gap-2"
                    >
                      {user.name}
                      <ArrowSquareOutIcon className="text-cream-muted size-4 shrink-0" />
                    </a>
                  </h3>
                  <p class="text-cream-muted mt-3 text-sm leading-relaxed">{user.description}</p>
                  <nav class="user-card-links" aria-label={`${user.name} links`}>
                    <a href={user.repo} target="_blank" rel="noreferrer" class="user-card-link">
                      <GithubLogoIcon className="size-3.5" />
                      GitHub
                    </a>
                    {user.crates && (
                      <a href={user.crates} target="_blank" rel="noreferrer" class="user-card-link">
                        <PackageIcon className="size-3.5" />
                        crates.io
                      </a>
                    )}
                    {user.docs && (
                      <a href={user.docs} target="_blank" rel="noreferrer" class="user-card-link">
                        <BookOpenIcon className="size-3.5" />
                        docs.rs
                      </a>
                    )}
                  </nav>
                </div>
              </article>
            ))
          }

          <article class="surface-card surface-card--cta animate-rise" style="animation-delay: 775ms">
            <div class="card-body">
              <div class="bg-terracotta/15 text-terracotta mb-4 inline-flex size-10 items-center justify-center rounded-xl">
                <UsersThreeIcon className="size-5" />
              </div>
              <h3 class="font-heading text-xl font-semibold">Add your project</h3>
              <p class="text-cream-muted mt-3 text-sm leading-relaxed">
                Fork the repo, add a row to
                <code class="code-inline mx-1">{USERS_FILE_PATH}</code>
                with your name, description, and links. Logo goes in
                <code class="code-inline mx-1">public/users/</code>
                if you have one; set <code class="code-inline mx-1">logo</code> in the entry.
              </p>
              <div class="user-card-links">
                <a href={USERS_SUBMISSION_URL} target="_blank" rel="noreferrer" class="btn btn-outline h-9 px-4 text-xs">
                  <PlusIcon className="size-4" />
                  Submit via GitHub
                </a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section
        class="section-anchor animate-rise delay-700 mt-24 grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-start"
        id="how-it-works"
      >
        <div class="space-y-5">
          <p class="text-terracotta text-xs font-medium tracking-[0.24em] uppercase">How it works</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight md:text-4xl">
            Generate the client. Send it yourself.
          </h2>
          <ol class="text-cream-muted space-y-4 text-sm leading-relaxed">
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">01</span>
              <span>Install the CLI and point it at your OpenAPI file.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">02</span>
              <span>Satay writes builders that produce IO-free <code class="code-inline">http::Request</code> values.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">03</span>
              <span>
                Send that request with reqwest, ureq, hyper, or your own client, then decode the response with the generated action types.
              </span>
            </li>
          </ol>

        </div>

        <div class="terminal-block lg:mt-8">
          <div class="terminal-header">
            <span class="terminal-dot bg-terracotta/80"></span>
            <span class="terminal-dot bg-cream-muted/40"></span>
            <span class="terminal-dot bg-cream-muted/25"></span>
            <span class="terminal-label">generate</span>
          </div>
          <pre class="terminal-pre"><code class="text-cream-muted"><span class="text-cream-muted/60">$</span> {GENERATE_CMD}
<span class="text-cream-muted/60">$</span> satay --help</code></pre>
        </div>
      </section>

      <footer
        class="border-border/40 animate-rise delay-800 mt-24 flex flex-col gap-6 border-t pt-8 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-cream-muted text-sm">Apache-2.0 / MIT · zeon256/satay-rs</p>
        <nav class="flex flex-wrap items-center gap-5 text-sm">
          <a href={DOCS_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            docs.rs
          </a>
          <a href={CRATES_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            crates.io
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            GitHub
          </a>
        </nav>
      </footer>
    </main>
  </div>
</Layout>
