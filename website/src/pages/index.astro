---
import Layout from "@/layouts/main.astro"
import { CopyButton } from "@/components/landing/CopyButton"
import { satayUsers, USERS_FILE_PATH, USERS_SUBMISSION_URL } from "@/data/users"
import { highlightRust, highlightToml, highlightYaml } from "@/lib/highlight"
import { SITEMAP_INDEX_PATH } from "@/lib/sitemap"
import { fetchProjectStats, formatDownloads, formatStars } from "@/lib/stats"
import {
  ArrowSquareOutIcon,
  BookOpenIcon,
  CodeIcon,
  DownloadSimpleIcon,
  GithubLogoIcon,
  GitBranchIcon,
  PackageIcon,
  PlugsIcon,
  PlusIcon,
  ShieldCheckIcon,
  StarIcon,
  UsersThreeIcon,
  WarningIcon,
  XCircleIcon,
  CheckCircleIcon,
} from "@phosphor-icons/react"

const GITHUB_URL = "https://github.com/zeon256/satay-rs"
const CRATES_URL = "https://crates.io/crates/satay-cli"
const DOCS_URL = "https://docs.rs/satay-codegen"
const REQWEST_EXAMPLE_TEST_URL = `${GITHUB_URL}/blob/main/examples/reqwest/src/main.rs#L35-L74`
const EXTENSIONS_DOCS_URL = `${GITHUB_URL}/blob/main/docs/extensions.md`
const NEA_CARGO_TOML_URL = "https://github.com/InfiniteUnion/nea-rs/blob/main/Cargo.toml"
const INSTALL_CMD = "cargo install satay-cli"
const GENERATE_CMD = "satay generate --input openapi.yaml --output src/generated --rustfmt"

const transportExamples = [
  {
    id: "reqwest",
    label: "reqwest",
    meta: "async",
    code: `use generated::{Api, BusServiceNumber};
use satay_reqwest::{reqwest, ReqwestActionExt};
use std::{env, error::Error};

#[tokio::main]
async fn main() -> Result<(), Box<dyn Error>> {
    let api = Api::new().account_key(env::var("LTA_ACCOUNT_KEY")?);
    let action = api
        .get_bus_arrival(83139)
        .service_no(BusServiceNumber::try_new("15")?);

    let _response = action
        .send_with(&reqwest::Client::new())
        .await?;

    Ok(())
}`,
  },
  {
    id: "reqwest-blocking",
    label: "reqwest",
    meta: "blocking",
    code: `use generated::{Api, BusServiceNumber};
use satay_reqwest::{reqwest, ReqwestBlockingActionExt};
use std::{env, error::Error};

fn main() -> Result<(), Box<dyn Error>> {
    let api = Api::new().account_key(env::var("LTA_ACCOUNT_KEY")?);
    let action = api
        .get_bus_arrival(83139)
        .service_no(BusServiceNumber::try_new("15")?);

    let _response = action
        .send_with(&reqwest::blocking::Client::new())?;

    Ok(())
}`,
  },
  {
    id: "ureq",
    label: "ureq",
    meta: "blocking",
    code: `use generated::{Api, BusServiceNumber};
use satay_ureq::{ureq, UreqActionExt};
use std::{env, error::Error};

fn main() -> Result<(), Box<dyn Error>> {
    let api = Api::new().account_key(env::var("LTA_ACCOUNT_KEY")?);
    let action = api
        .get_bus_arrival(83139)
        .service_no(BusServiceNumber::try_new("15")?);

    let agent: ureq::Agent = ureq::Agent::config_builder()
        .http_status_as_error(false)
        .build()
        .into();

    let _response = action.send_with(&agent)?;

    Ok(())
}`,
  },
  {
    id: "diy",
    label: "DIY",
    meta: "sans-IO",
    code: `use generated::{Api, BusServiceNumber, GetBusArrivalAction};
use satay_runtime::ResponseParts;
use std::{env, error::Error, mem};

#[tokio::main]
async fn main() -> Result<(), Box<dyn Error>> {
    let api = Api::new().account_key(env::var("LTA_ACCOUNT_KEY")?);
    let action = api
        .get_bus_arrival(83139)
        .service_no(BusServiceNumber::try_new("15")?);

    let request: reqwest::Request = action.request()?.try_into()?;
    let mut response = reqwest::Client::new().execute(request).await?;

    let _decoded = GetBusArrivalAction::decode(ResponseParts {
        status: response.status(),
        headers: mem::take(response.headers_mut()),
        body: response.bytes().await?,
    })?;

    Ok(())
}`,
  },
] as const

const testingExampleCode = `use generated::{
    Api, BusServiceNumber, GetBusArrivalAction,
    GetBusArrivalResponse,
};
use std::error::Error;

#[test]
fn tests_the_api_without_http() -> Result<(), Box<dyn Error>> {
    let api = Api::new().base_url("").account_key("test-key");
    let action = api
        .get_bus_arrival(83139)
        .service_no(BusServiceNumber::try_new("15")?);

    let request = action.request()?;
    assert_eq!(request.method(), http::Method::GET);
    assert_eq!(request.uri().path(), "/v3/BusArrival");
    assert_eq!(request.headers()["AccountKey"], "test-key");

    let query = request.uri().query().unwrap_or_default();
    assert!(query.contains("BusStopCode=83139"));
    assert!(query.contains("ServiceNo=15"));

    let response = GetBusArrivalAction::decode(
        satay_runtime::ResponseParts {
            status: http::StatusCode::OK,
            headers: http::HeaderMap::new(),
            body: br#"{
                "odata.metadata": "https://datamall2.mytransport.sg/ltaodataservice/v3/BusArrival",
                "BusStopCode": "83139",
                "Services": []
            }"#,
        },
    )?;

    let GetBusArrivalResponse::Ok(arrival) = response else {
        panic!("expected 200 OK bus arrival response");
    };
    assert_eq!(arrival.bus_stop_code, 83139);
    assert!(arrival.services.is_empty());
    Ok(())
}`

const neaCargoTomlCode = `# library API: no reqwest, ureq, hyper, or TLS backend
[dependencies]
satay-runtime = { version = "0.1.2", default-features = false }
nutype = { version = "0.7", features = ["serde", "regex"] }
regex = "1"
serde = { version = "1", features = ["derive"], optional = true }
serde_json = { version = "1", optional = true }
http = "1"`

const extensions = [
  {
    id: "parse-as",
    label: "parse-as",
    meta: "typed",
    title: "Parse wire strings as stronger types",
    body: `Use on <code class="code-inline">type: string</code> schemas when an API sends JSON strings but the Rust field should be a number, date, or time. Serde keeps the wire format as a string.`,
    types: [
      "u8",
      "u16",
      "u32",
      "u64",
      "i8",
      "i16",
      "i32",
      "i64",
      "f32",
      "f64",
      "bool",
      "date",
      "naive-datetime",
      "offset-datetime",
      "time",
    ],
    yamlCode: `BusStopCode:
  type: string
  x-satay:
    parse-as: u32

EstimatedArrival:
  type: string
  x-satay:
    parse-as: offset-datetime

Monitored:
  type: integer
  x-satay:
    parse-as: bool`,
    rustCode: `pub struct Bus {
    #[cfg_attr(feature = "serde", serde(with = "satay_runtime::serde_string::as_u32"))]
    pub bus_stop_code: u32,

    #[cfg_attr(feature = "serde", serde(with = "satay_runtime::serde_string::as_offset_datetime"))]
    pub estimated_arrival: satay_runtime::OffsetDateTime,

    #[cfg_attr(feature = "serde", serde(with = "satay_runtime::serde_integer::as_bool"))]
    pub monitored: bool,
}`,
  },
  {
    id: "integer-type",
    label: "integer-type",
    meta: "integers",
    title: "Override inferred integer primitives",
    body: `Satay infers the smallest Rust integer from <code class="code-inline">minimum</code> and <code class="code-inline">maximum</code> bounds. Use <code class="code-inline">integer-type</code> to opt out or pick a specific primitive. <code class="code-inline">auto</code> is the default.`,
    types: ["auto", "u8", "u16", "u32", "u64", "i8", "i16", "i32", "i64"],
    yamlCode: `Direction:
  type: integer
  format: int32
  description: >
    The direction in which the bus travels. Valid values are 1 or 2;
    loop services only have 1 direction.
  example: 1
  minimum: 1
  maximum: 2`,
    rustCode: `/// The direction in which the bus travels. Valid values are 1 or 2; loop services only have 1 direction.
#[nutype::nutype(
    validate(greater_or_equal = 1, less_or_equal = 2),
    derive(
        Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord, AsRef, Deref, TryFrom, Into, Display
    ),
    cfg_attr(feature = "serde", derive(Serialize, Deserialize))
)]
pub struct BusRouteDirection(u8);`,
  },
  {
    id: "enum-variants",
    label: "enum-variants",
    meta: "rename",
    title: "Descriptive enum variant names",
    body: `Map terse wire values to readable Rust variants. Mapping a value to <code class="code-inline">Unknown</code> folds it into Satay's generated fallback variant.`,
    types: null,
    yamlCode: `Type:
  type: string
  description: >
    Vehicle type of the bus.
  enum: [SD, DD, BD, ""]
  example: SD
  x-satay:
    enum-variants:
      SD: SingleDecker
      DD: DoubleDecker
      BD: Bendy
      "": Unknown`,
    rustCode: `/// Vehicle type of the bus.
#[derive(Debug, Clone, PartialEq, Eq, Default)]
#[cfg_attr(feature = "serde", derive(serde::Serialize, serde::Deserialize))]
pub enum BusArrivalTimingType {
    #[cfg_attr(feature = "serde", serde(rename = "SD"))]
    SingleDecker,
    #[cfg_attr(feature = "serde", serde(rename = "DD"))]
    DoubleDecker,
    #[cfg_attr(feature = "serde", serde(rename = "BD"))]
    Bendy,
    #[default]
    #[cfg_attr(feature = "serde", serde(other))]
    Unknown,
}`,
  },
  {
    id: "treat-error-as-none",
    label: "treat-error-as-none",
    meta: "optional",
    title: "Treat deserialization errors as None",
    body: `Make a field <code class="code-inline">Option&lt;T&gt;</code>. When nested deserialization fails, the field resolves to <code class="code-inline">None</code> instead of failing the whole response. Requires the generated crate's <code class="code-inline">json</code> feature.`,
    types: null,
    yamlCode: `BusServiceArrival:
  type: object
  required: [ServiceNo, NextBus]
  properties:
    ServiceNo:
      type: string
    NextBus:
      $ref: "#/components/schemas/BusArrivalTiming"
      x-satay:
        treat-error-as-none: true`,
    rustCode: `pub struct BusServiceArrival {
    pub service_no: String,
    #[cfg_attr(feature = "serde", serde(
        rename = "NextBus",
        deserialize_with = "satay_runtime::treat_error_as_none::deserialize",
        serialize_with = "satay_runtime::treat_error_as_none::serialize",
        default,
        skip_serializing_if = "Option::is_none"
    ))]
    pub next_bus: Option<BusArrivalTiming>,
}`,
  },
] as const

const [
  { crateDownloads, githubStars },
  highlightedTransportExamples,
  testingExampleHtml,
  neaCargoTomlHtml,
  highlightedExtensions,
] = await Promise.all([
  fetchProjectStats(),
  Promise.all(
    transportExamples.map(async (example) => ({
      ...example,
      html: await highlightRust(example.code),
    })),
  ),
  highlightRust(testingExampleCode),
  highlightToml(neaCargoTomlCode),
  Promise.all(
    extensions.map(async (extension) => ({
      ...extension,
      yamlHtml: await highlightYaml(extension.yamlCode),
      rustHtml: extension.rustCode ? await highlightRust(extension.rustCode) : null,
    })),
  ),
])

const sectionLinks = [
  { href: "#compare", label: "Compare" },
  { href: "#why-sans-io", label: "sans-IO" },
  { href: "#features", label: "Features" },
  { href: "#extensions", label: "Extensions" },
  { href: "#users", label: "Users" },
  { href: "#how-it-works", label: "How it works" },
]

const comparisonPoints = [
  {
    title: "The action stops at HTTP",
    body: "The generated builder knows the path, query, headers, validation, and response enum. The adapter just runs the resulting <code class=\"code-inline\">http::Request</code>.",
  },
  {
    title: "Runtime stays outside",
    body: "Async reqwest awaits. Blocking reqwest returns. ureq uses its agent. A manual transport can drive the raw request/response boundary.",
  },
  {
    title: "Swap backends freely",
    body: "Add ureq, hyper, a test harness, or WASM without regenerating a transport-owned SDK.",
  },
]

const sansIoContrast = [
  {
    title: "Without sans-IO",
    points: [
      "Async, blocking, and WASM often fork into separate client code",
      "A reqwest or hyper bump can become a release for your SDK",
      "Changing transports usually means refactoring client internals",
      "Tests tend to need real HTTP or mocks around the whole stack",
    ],
    icon: XCircleIcon,
    variant: "without" as const,
  },
  {
    title: "With Satay",
    points: [
      "One generated API for building requests and decoding responses",
      "Transport adapters are optional and thin; your app keeps its HTTP client",
      "Regenerate when the OpenAPI spec changes, not when reqwest bumps",
      "Unit tests can build requests and decode fixture responses offline",
    ],
    icon: CheckCircleIcon,
    variant: "with" as const,
  },
]

const features = [
  {
    title: "sans-IO first",
    body: "Actions build plain <code class=\"code-inline\">http::Request</code> values. Send them with reqwest, ureq, hyper, a test harness, WASM, or whatever you already use.",
    icon: PlugsIcon,
  },
  {
    title: "Validation newtypes",
    body: "String, number, integer, and array constraints from the spec become nutype newtypes. A max of 255 becomes <code class=\"code-inline\">u8</code> instead of a bare integer.",
    icon: ShieldCheckIcon,
  },
  {
    title: "OpenAPI 3.1",
    body: "The spec is parsed into a normalized IR, then emitted as structs, enums, builders, and decoders you can read and edit.",
    icon: CodeIcon,
  },
  {
    title: "Optional adapters",
    body: "Stay IO-free, or add <code class=\"code-inline\">satay-reqwest</code> / <code class=\"code-inline\">satay-ureq</code> for a one-line <code class=\"code-inline\">send_with</code> call site.",
    icon: GitBranchIcon,
  },
]

---

<Layout>
  <div id="top" class="relative flex min-h-svh flex-col overflow-x-clip">
    <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
      <div class="bg-terracotta/12 absolute -top-28 right-[8%] size-72 rounded-none blur-3xl"></div>
      <div class="bg-ember/10 absolute bottom-[18%] -left-20 size-64 rounded-none blur-3xl"></div>
      <div class="skewer-diagonal absolute inset-0"></div>
    </div>

    <div class="site-chrome animate-rise fixed inset-x-0 top-0 z-50">
      <aside class="site-banner" role="note">
        <div class="site-banner-inner">
          <WarningIcon className="text-ember size-3.5 shrink-0" />
          <p class="text-cream-muted min-w-0 text-xs leading-snug">
            <span class="text-cream font-medium">Work in progress.</span>
            Focused on lta-rs-style clients for now.
          </p>
        </div>
      </aside>

      <header class="site-header">
        <div class="site-header-inner">
          <a href="#top" class="group flex shrink-0 items-center gap-3">
            <img
              src="/logo.webp"
              alt="Satay"
              width="36"
              height="36"
              class="size-9 rounded-none shadow-md shadow-black/40 transition-transform group-hover:scale-[1.03]"
            />
            <span class="font-heading text-lg font-semibold tracking-tight">Satay</span>
          </a>

          <div class="header-nav-cluster">
            <nav class="header-section-nav" aria-label="Page sections">
              {
                sectionLinks.map((link) => (
                  <a href={link.href} class="header-section-link">
                    {link.label}
                  </a>
                ))
              }
            </nav>

            <div class="header-nav-divider" aria-hidden="true"></div>

            <nav class="header-external-nav" aria-label="External links">
              <a href={DOCS_URL} target="_blank" rel="noreferrer" class="btn-ghost">
                <BookOpenIcon className="size-4" />
                <span class="hidden sm:inline">Docs</span>
              </a>
              <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="btn-ghost">
                <GithubLogoIcon className="size-4" />
                <span class="hidden sm:inline">GitHub</span>
              </a>
            </nav>
          </div>
        </div>
      </header>
    </div>

    <main class="main-with-fixed-chrome relative z-10 mx-auto flex w-full max-w-6xl flex-1 flex-col px-6 pb-20 md:px-10">
      <div class="grid items-center gap-14 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.95fr)] lg:gap-16">
        <section class="flex flex-col gap-8">
          <p class="meta-row animate-rise delay-150" aria-label="Project metadata">
            <span class="text-terracotta">sans-IO</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>OpenAPI 3.1</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>Rust 2024</span>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>MSRV 1.88</span>
          </p>

          {(crateDownloads !== null || githubStars !== null) && (
            <div class="stat-row animate-rise delay-175">
              {crateDownloads !== null && (
                <a href={CRATES_URL} target="_blank" rel="noreferrer" class="stat-pill">
                  <DownloadSimpleIcon className="size-3.5" />
                  {formatDownloads(crateDownloads)}
                </a>
              )}
              {githubStars !== null && (
                <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="stat-pill">
                  <StarIcon className="size-3.5" weight="fill" />
                  {formatStars(githubStars)}
                </a>
              )}
            </div>
          )}

          <div class="animate-rise delay-200 space-y-5">
            <h1
              class="font-heading text-[2.75rem] leading-[1.02] font-semibold tracking-tight text-balance md:text-6xl lg:text-[4.25rem]"
            >
              Rust OpenAPI clients
              <span class="text-terracotta block">without HTTP lock-in</span>
            </h1>
            <p class="text-cream-muted max-w-xl text-base leading-relaxed text-pretty md:text-lg">
              Satay reads an OpenAPI 3.1 spec and writes Rust for building requests and decoding responses.
              You get the <code class="code-inline">http::Request</code>. Your app sends it.
            </p>
          </div>

          <div class="animate-rise delay-300 flex flex-wrap items-center gap-3">
            <a href={CRATES_URL} target="_blank" rel="noreferrer" class="btn btn-primary">
              <DownloadSimpleIcon className="size-5" />
              Install CLI
            </a>
            <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="btn btn-outline">
              <GithubLogoIcon className="size-5" />
              View source
            </a>
          </div>

          <div class="animate-rise delay-400 w-full max-w-lg space-y-2">
            <p class="section-label text-cream-muted">Quick start</p>
            <div class="terminal-block">
              <div class="terminal-header">
                <span class="terminal-dot bg-terracotta/80"></span>
                <span class="terminal-dot bg-cream-muted/40"></span>
                <span class="terminal-dot bg-cream-muted/25"></span>
                <span class="terminal-label">shell</span>
              </div>
              <div class="flex items-center justify-between gap-3 px-4 py-3.5">
                <code class="terminal-code">{INSTALL_CMD}</code>
                <CopyButton client:load value={INSTALL_CMD} label="Copy install command" />
              </div>
            </div>
          </div>
        </section>

        <section class="animate-rise delay-500 relative hidden items-center justify-center lg:flex">
          <div
            class="bg-terracotta-deep/25 absolute inset-[12%] rounded-none blur-3xl"
            aria-hidden="true"
          >
          </div>
          <img
            src="/logo.webp"
            alt="Satay logo: cubes on a skewer"
            width="480"
            height="480"
            fetchpriority="high"
            class="animate-logo-float relative z-10 w-full max-w-[22rem] drop-shadow-2xl drop-shadow-black/60 lg:max-w-[26rem]"
          />
        </section>
      </div>

      <section class="section-anchor animate-rise delay-550 mt-24" id="compare">
        <div class="section-intro">
          <p class="section-label">Same action, different transports</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            One operation, many ways to send it
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Satay generates a typed action for each API operation. Async reqwest, blocking reqwest, ureq, and a custom
            client all start from the same action.
          </p>
        </div>

        <div class="code-compare-grid" aria-label="Transport examples">
          <div class="transport-tabs">
            {
              highlightedTransportExamples.map((example, index) => (
                <input
                  class="transport-tab-input"
                  type="radio"
                  name="transport-example"
                  id={`transport-tab-${example.id}`}
                  checked={index === 0}
                />
              ))
            }

            <div class="transport-tab-list" role="tablist" aria-label="Transport choices">
              {
                highlightedTransportExamples.map((example) => (
                  <label class="transport-tab-label" for={`transport-tab-${example.id}`} role="tab">
                    <span class="transport-tab-label-main">{example.label}</span>
                    <span class="transport-tab-label-meta">{example.meta}</span>
                  </label>
                ))
              }
            </div>

            <div class="transport-tab-panels">
              {
                highlightedTransportExamples.map((example) => (
                  <article class:list={["transport-tab-panel", `transport-tab-panel--${example.id}`]}>
                    <pre class="code-compare-pre"><code class="highlight-code language-rust" set:html={example.html} /></pre>
                  </article>
                ))
              }
            </div>
          </div>
        </div>

        <div class="compare-point-grid">
          {
            comparisonPoints.map((point) => (
              <article class="compare-point-card">
                <h3 class="font-heading text-lg font-semibold tracking-tight">{point.title}</h3>
                <p class="text-cream-muted mt-2 text-sm leading-relaxed" set:html={point.body} />
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-anchor animate-rise delay-575 mt-24" id="why-sans-io">
        <div class="section-intro">
          <p class="section-label">Why sans-IO</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            Keep the API layer, swap the HTTP client
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Most OpenAPI clients ship with a transport baked in. Your SDK ends up tracking reqwest releases, TLS changes,
            and separate async, blocking, and WASM paths. Satay generates the API layer only. You send the requests.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            sansIoContrast.map((side, index) => {
              const Icon = side.icon
              return (
                <article
                  class:list={["contrast-card animate-rise", side.variant === "with" && "contrast-card--with"]}
                  style={`animation-delay: ${600 + index * 75}ms`}
                >
                  <div class="card-body">
                    <div class="mb-5 flex items-center gap-3">
                      <div
                        class:list={[
                          "inline-flex size-10 items-center justify-center rounded-none",
                          side.variant === "with" ? "bg-terracotta/15 text-terracotta" : "bg-cream/5 text-cream-muted",
                        ]}
                      >
                        <Icon className="size-5" weight={side.variant === "with" ? "fill" : "regular"} />
                      </div>
                      <h3 class="font-heading text-xl font-semibold">{side.title}</h3>
                    </div>
                    <ul class="contrast-list">
                      {side.points.map((point) => (
                        <li class="contrast-list-item">
                          <span class="contrast-list-marker" aria-hidden="true"></span>
                          <span>{point}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </article>
              )
            })
          }
        </div>

        <p class="text-cream-muted mt-8 max-w-2xl text-base leading-relaxed">
          You maintain the OpenAPI spec. Satay emits typed Rust. When the API changes, update the spec and regenerate.
          The HTTP client stays separate.
        </p>

        <div class="test-example-shell animate-rise mt-12" style="animation-delay: 725ms">
          <div class="test-example-copy">
            <p class="section-label">Tests</p>
            <h3 class="font-heading text-2xl font-semibold tracking-tight text-balance md:text-3xl">
              Test the client without HTTP
            </h3>
            <p class="text-cream-muted text-base leading-relaxed">
              Actions expose request construction and response decoding as plain functions. Tests can assert the outgoing
              request and feed fixture bytes through the decoder. No live server, no reqwest mock, no async runtime.
            </p>
            <a href={REQWEST_EXAMPLE_TEST_URL} target="_blank" rel="noreferrer" class="test-example-link">
              <GithubLogoIcon className="size-4" />
              View in reqwest example
              <ArrowSquareOutIcon className="size-3.5" />
            </a>
          </div>

          <article class="code-panel">
            <div class="code-panel-bar">
              <span class="code-panel-filename">test.rs</span>
            </div>
            <pre class="code-compare-pre"><code class="highlight-code language-rust" set:html={testingExampleHtml} /></pre>
          </article>
        </div>

        <div class="test-example-shell animate-rise mt-14" style="animation-delay: 800ms">
          <div class="test-example-copy">
            <p class="section-label">Library dependencies</p>
            <h3 class="font-heading text-2xl font-semibold tracking-tight text-balance md:text-3xl">
              Your library does not need to depend on an HTTP backend
            </h3>
            <p class="text-cream-muted text-base leading-relaxed">
              In a generated client crate like <code class="code-inline">nea-rs</code>, the library depends on Satay
              runtime, <code class="code-inline">http</code>, and serialization. Reqwest shows up in dev-dependencies
              for examples and tests.
            </p>
            <a href={NEA_CARGO_TOML_URL} target="_blank" rel="noreferrer" class="test-example-link">
              <GithubLogoIcon className="size-4" />
              View nea-rs Cargo.toml
              <ArrowSquareOutIcon className="size-3.5" />
            </a>
          </div>

          <article class="code-panel">
            <div class="code-panel-bar">
              <span class="code-panel-filename">Cargo.toml</span>
            </div>
            <pre class="code-compare-pre"><code class="highlight-code language-toml" set:html={neaCargoTomlHtml} /></pre>
          </article>
        </div>
      </section>

      <section class="section-anchor animate-rise delay-600 mt-24" id="features">
        <div class="section-intro">
          <p class="section-label">Features</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            Generated Rust you can read
          </h2>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            features.map((feature, index) => {
              const Icon = feature.icon
              return (
                <article class="surface-card surface-card--feature animate-rise" style={`animation-delay: ${650 + index * 75}ms`}>
                  <div class="card-art" aria-hidden="true">
                    <div class="card-art-well">
                      <Icon className="card-art-icon" weight="thin" />
                    </div>
                  </div>
                  <div class="card-body">
                    <h3 class="font-heading mb-2 text-xl font-semibold">{feature.title}</h3>
                    <p class="text-cream-muted text-sm leading-relaxed" set:html={feature.body} />
                  </div>
                </article>
              )
            })
          }
        </div>
      </section>

      <section class="section-anchor animate-rise delay-625 mt-24" id="extensions">
        <div class="section-intro">
          <p class="section-label">x-satay extensions</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            When the spec alone is not enough
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Most schemas map cleanly to Rust. For the rest, annotate the OpenAPI with
            <code class="code-inline">x-satay</code> vendor extensions and regenerate.
          </p>
        </div>

        <div class="extension-tabs" aria-label="Satay OpenAPI extensions">
          {
            highlightedExtensions.map((extension, index) => (
              <input
                class="extension-tab-input"
                type="radio"
                name="extension-example"
                id={`extension-tab-${extension.id}`}
                checked={index === 0}
              />
            ))
          }

          <div class="extension-tab-list" role="tablist" aria-label="Extension choices">
            {
              highlightedExtensions.map((extension) => (
                <label class="extension-tab-label" for={`extension-tab-${extension.id}`} role="tab">
                  <span class="extension-tab-label-main">{extension.label}</span>
                  <span class="extension-tab-label-meta">{extension.meta}</span>
                </label>
              ))
            }
          </div>

          <div class="extension-tab-panels">
            {
              highlightedExtensions.map((extension) => (
                <article class:list={["extension-tab-panel", `extension-tab-panel--${extension.id}`]}>
                  <div class="extension-panel-shell">
                    <div class="extension-panel-copy">
                      <h3 class="extension-panel-title">{extension.title}</h3>
                      <p class="text-cream-muted text-sm leading-relaxed" set:html={extension.body} />
                      {
                        extension.types && (
                          <div>
                            <p class="text-cream-muted mb-2 text-xs font-medium tracking-wide uppercase">
                              Supported values
                            </p>
                            <div class="extension-type-list">
                              {extension.types.map((typeName) => (
                                <span class="extension-type-chip">{typeName}</span>
                              ))}
                            </div>
                          </div>
                        )
                      }
                    </div>

                    <div class="extension-code-stack">
                      <article class="code-panel">
                        <div class="code-panel-bar">
                          <span class="code-panel-filename">openapi.yaml</span>
                        </div>
                        <pre class="code-compare-pre"><code class="highlight-code language-yaml" set:html={extension.yamlHtml} /></pre>
                      </article>
                      {
                        extension.rustHtml && (
                          <article class="code-panel">
                            <div class="code-panel-bar">
                              <span class="code-panel-filename">generated.rs</span>
                            </div>
                            <pre class="code-compare-pre"><code class="highlight-code language-rust" set:html={extension.rustHtml} /></pre>
                          </article>
                        )
                      }
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>

        <p class="text-cream-muted mt-6 text-sm leading-relaxed">
          Full reference in
          <a href={EXTENSIONS_DOCS_URL} target="_blank" rel="noreferrer" class="test-example-link mx-1">
            docs/extensions.md
            <ArrowSquareOutIcon className="size-3.5" />
          </a>
          on GitHub.
        </p>
      </section>

      <section class="section-anchor animate-rise delay-650 mt-24" id="users">
        <div class="section-intro">
          <p class="section-label">Built with Satay</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            In the wild
          </h2>
          <p class="text-cream-muted text-base leading-relaxed">
            Open-source clients using Satay. Missing yours? Send a PR.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {
            satayUsers.map((user, index) => (
              <article
                class="surface-card animate-rise"
                style={`animation-delay: ${700 + index * 75}ms`}
              >
                <div class="card-art" aria-hidden="true">
                  <div class:list={["card-art-well", !user.logo && "card-art-well--mark"]}>
                    {
                      user.logo ? (
                        <img
                          src={user.logo}
                          alt=""
                          class="card-art-image"
                          loading="lazy"
                          decoding="async"
                        />
                      ) : (
                        <span class="card-art-mark">{user.name.slice(0, 2)}</span>
                      )
                    }
                  </div>
                </div>
                <div class="card-body">
                  <h3 class="font-heading text-xl font-semibold">
                    <a
                      href={user.href}
                      target="_blank"
                      rel="noreferrer"
                      class="user-card-title inline-flex items-center gap-2"
                    >
                      {user.name}
                      <ArrowSquareOutIcon className="text-cream-muted size-4 shrink-0" />
                    </a>
                  </h3>
                  <p class="text-cream-muted mt-3 text-sm leading-relaxed">{user.description}</p>
                  <nav class="user-card-links" aria-label={`${user.name} links`}>
                    <a href={user.repo} target="_blank" rel="noreferrer" class="user-card-link">
                      <GithubLogoIcon className="size-3.5" />
                      GitHub
                    </a>
                    {user.crates && (
                      <a href={user.crates} target="_blank" rel="noreferrer" class="user-card-link">
                        <PackageIcon className="size-3.5" />
                        crates.io
                      </a>
                    )}
                    {user.docs && (
                      <a href={user.docs} target="_blank" rel="noreferrer" class="user-card-link">
                        <BookOpenIcon className="size-3.5" />
                        docs.rs
                      </a>
                    )}
                  </nav>
                </div>
              </article>
            ))
          }

          <article class="surface-card surface-card--cta animate-rise" style="animation-delay: 775ms">
            <div class="card-body">
              <div class="bg-terracotta/15 text-terracotta mb-4 inline-flex size-10 items-center justify-center rounded-none">
                <UsersThreeIcon className="size-5" />
              </div>
              <h3 class="font-heading text-xl font-semibold">Add your project</h3>
              <p class="text-cream-muted mt-3 text-sm leading-relaxed">
                Fork the repo, add a row to
                <code class="code-inline mx-1">{USERS_FILE_PATH}</code>
                with your name, description, and links. Logo goes in
                <code class="code-inline mx-1">public/users/</code>
                if you have one; set <code class="code-inline mx-1">logo</code> in the entry.
              </p>
              <div class="user-card-links">
                <a href={USERS_SUBMISSION_URL} target="_blank" rel="noreferrer" class="btn btn-outline h-9 px-4 text-xs">
                  <PlusIcon className="size-4" />
                  Submit via GitHub
                </a>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section
        class="section-anchor animate-rise delay-700 mt-24 grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,0.95fr)] lg:items-start"
        id="how-it-works"
      >
        <div class="space-y-5">
          <p class="section-label">How it works</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            Generate the client, send it yourself
          </h2>
          <ol class="text-cream-muted space-y-4 text-sm leading-relaxed">
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">01</span>
              <span>Install the CLI and point it at your OpenAPI file.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">02</span>
              <span>Satay writes builders that produce IO-free <code class="code-inline">http::Request</code> values.</span>
            </li>
            <li class="flex gap-3">
              <span class="text-ember font-heading text-lg leading-none">03</span>
              <span>
                Send the request with reqwest, ureq, hyper, or your own client, then decode the response with the
                generated types.
              </span>
            </li>
          </ol>

        </div>

        <div class="terminal-block lg:mt-8">
          <div class="terminal-header">
            <span class="terminal-dot bg-terracotta/80"></span>
            <span class="terminal-dot bg-cream-muted/40"></span>
            <span class="terminal-dot bg-cream-muted/25"></span>
            <span class="terminal-label">generate</span>
          </div>
          <pre class="terminal-pre"><code class="text-cream-muted"><span class="text-cream-muted/60">$</span> {GENERATE_CMD}
<span class="text-cream-muted/60">$</span> satay --help</code></pre>
        </div>
      </section>

      <section class="section-anchor animate-rise delay-700 mt-24" id="origin">
        <div class="section-intro">
          <p class="section-label">Origin</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-balance md:text-4xl">
            Named for the skewer, not the sauce
          </h2>
        </div>

        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-stretch lg:gap-16">
          <div class="space-y-6">
            <article class="origin-entry" aria-label="Dictionary entry for sate">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <p class="origin-headword">sate</p>
                <p class="origin-pronunciation">/ˈsɑː.teɪ/</p>
                <p class="origin-pronunciation italic">n.</p>
                <p class="origin-pronunciation">(Malay, Indonesian)</p>
              </div>
              <p class="origin-gloss">
                a skewer; meat (or other food) cut into pieces, threaded onto a skewer, and grilled.
              </p>
            </article>

            <div class="text-cream-muted text-base leading-relaxed">
              <p>
                English <strong class="text-cream font-medium">satay</strong> comes from the Malay and Indonesian word
                <strong class="text-cream font-medium">sate</strong>, which refers to both the skewer and the dish.
                Street vendors thread marinated pieces onto bamboo sticks, grill them over charcoal, and serve them with
                peanut sauce. The name caught on abroad as the dish spread across Southeast Asia.
              </p>
            </div>
          </div>

          <article class="contrast-card contrast-card--with origin-metaphor-card">
            <div class="card-body space-y-6">
              <div class="space-y-3">
                <p class="section-label">The metaphor</p>
                <p class="text-cream-muted text-base leading-relaxed">
                  The name is the metaphor. OpenAPI holds the pieces: schemas, operations, constraints. Codegen threads
                  them into request builders and response decoders. Your app picks the transport. The skewer is the
                  sans-IO boundary; the pieces do not change when you swap grills.
                </p>
              </div>

              <ol class="origin-metaphor-list" aria-label="How the skewer metaphor maps to Satay">
                <li class="origin-metaphor-item">
                  <span class="origin-metaphor-marker" aria-hidden="true"></span>
                  <div>
                    <p class="text-cream font-medium">OpenAPI spec</p>
                    <p class="text-cream-muted mt-1 text-sm leading-relaxed">Schemas, operations, and constraints.</p>
                  </div>
                </li>
                <li class="origin-metaphor-item">
                  <span class="origin-metaphor-marker" aria-hidden="true"></span>
                  <div>
                    <p class="text-cream font-medium">Codegen</p>
                    <p class="text-cream-muted mt-1 text-sm leading-relaxed">
                      Threads them into builders and decoders you can read.
                    </p>
                  </div>
                </li>
                <li class="origin-metaphor-item">
                  <span class="origin-metaphor-marker" aria-hidden="true"></span>
                  <div>
                    <p class="text-cream font-medium">Your transport</p>
                    <p class="text-cream-muted mt-1 text-sm leading-relaxed">
                      reqwest, ureq, hyper, a test harness, WASM, or your own client.
                    </p>
                  </div>
                </li>
                <li class="origin-metaphor-item">
                  <span class="origin-metaphor-marker" aria-hidden="true"></span>
                  <div>
                    <p class="text-cream font-medium">sans-IO boundary</p>
                    <p class="text-cream-muted mt-1 text-sm leading-relaxed">The skewer. Same pieces, different grill.</p>
                  </div>
                </li>
              </ol>
            </div>
          </article>
        </div>
      </section>

      <footer
        class="border-border/40 animate-rise delay-800 mt-24 flex flex-col gap-6 border-t pt-8 sm:flex-row sm:items-center sm:justify-between"
      >
        <p class="text-cream-muted text-sm">Apache-2.0 / MIT · zeon256/satay-rs</p>
        <nav class="flex flex-wrap items-center gap-5 text-sm">
          <a href={DOCS_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            docs.rs
          </a>
          <a href={CRATES_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            crates.io
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noreferrer" class="footer-link">
            <ArrowSquareOutIcon className="size-3.5" />
            GitHub
          </a>
          <a href={SITEMAP_INDEX_PATH} class="footer-link">Sitemap</a>
        </nav>
      </footer>
    </main>
  </div>
</Layout>
